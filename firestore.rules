// Firestore Security Rules for OmnID
//
// Deploy these rules via the Firebase Console or the Firebase CLI:
//   firebase deploy --only firestore:rules
//
// These rules ensure:
//  1. Only authenticated users can read/write data.
//  2. Users can only access their own document (keyed by email).
//  3. All other collections/documents are denied by default.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user's data is stored at users/{email}.
    // Only the owner (matching auth token email) may read or write.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.token.email == userId;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
